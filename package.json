{
  "name": "vostok",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @vostok/web",
    "build:web": "npm run build --workspace @vostok/web",
    "build:desktop": "cd apps/desktop && npm run build",
    "sign:desktop": "cd apps/desktop && npm run sign",
    "package:desktop": "cd apps/desktop && npm run package:release",
    "release:desktop": "cd apps/desktop && npm run release",
    "manifest:desktop": "node ops/generate-desktop-release-manifest.mjs",
    "promote:desktop:stable": "node ops/promote-desktop-release.mjs --channel stable",
    "rollback:desktop:stable": "node ops/rollback-desktop-release.mjs --channel stable",
    "dev:web": "npm run dev --workspace @vostok/web",
    "dev:desktop": "cd apps/desktop && npm run dev",
    "setup:desktop": "cd apps/desktop && npm install",
    "lint:web": "npm run lint --workspace @vostok/web",
    "dev:server": "cd apps/server && mix phx.server",
    "setup:server": "cd apps/server && mix setup",
    "test:server": "cd apps/server && mix test",
    "format:server": "cd apps/server && mix format"
  }
}
